---
import DocPageLayout from '../../layouts/DocPageLayout.astro';
import StatsRow from '../../components/StatsRow.astro';
import SamplesTable from '../../components/SamplesTable.astro';
import SeeAlso from '../../components/SeeAlso.astro';
import { routes } from '../../lib/routes';
import { canonicalUrl } from '../../lib/seo';
import {
  getTypeFacets, getTopicsForType, getLanguagesForType, getSamplesByType,
  TOPIC_LABELS, TYPE_COPY,
} from '../../lib/data';

export async function getStaticPaths() {
  const types = await getTypeFacets();
  return types.map(t => ({ params: { type: t.id }, props: { typeFacet: t } }));
}

const { type } = Astro.params;
const { typeFacet } = Astro.props;

const [topics, langs, samples] = await Promise.all([
  getTopicsForType(type!),
  getLanguagesForType(type!),
  getSamplesByType(type!, 5),
]);

const label = typeFacet.label;
const count = typeFacet.count;
const topLangCodes = langs.languages.slice(0, 5).map(l => l.code).join(', ');
const copy = TYPE_COPY[type!];

const title = `${label} Word documents: ${count.toLocaleString()} classified .docx files`;
const description = `${count.toLocaleString()}+ ${label.toLowerCase()} Word documents from the public web, in ${langs.distinct}+ languages including ${topLangCodes}. Free open dataset from docx-corpus.`;

const accessExample = `# All ${label.toLowerCase()} documents
curl "https://api.docxcorp.us/manifest?type=${type}" -o ${type}-manifest.txt

# High-confidence English subset
curl "https://api.docxcorp.us/manifest?type=${type}&lang=en&min_confidence=0.8"`;

const structuredData = {
  '@context': 'https://schema.org',
  '@type': 'Dataset',
  name: `docx-corpus - ${label} Documents`,
  description,
  url: canonicalUrl(routes.type(type!)),
  isPartOf: {
    '@type': 'Dataset',
    name: 'docx-corpus',
    url: canonicalUrl(routes.home()),
    license: 'https://opendatacommons.org/licenses/by/1-0/',
    creator: { '@type': 'Organization', name: 'SuperDoc', url: 'https://superdoc.dev' },
  },
  license: 'https://opendatacommons.org/licenses/by/1-0/',
  creator: { '@type': 'Organization', name: 'SuperDoc', url: 'https://superdoc.dev' },
};
---

<DocPageLayout
  title={title}
  description={description}
  canonicalPath={routes.type(type!)}
  structuredData={structuredData}
  crumb={[
    { name: 'Home', path: routes.home() },
    { name: 'Types', path: routes.typesIndex() },
    { name: label },
  ]}
>
  <div class="hero">
    <div class="kicker">Document type · {type}</div>
    <h1>{label} Word documents</h1>
    <p class="sub">{count.toLocaleString()} documents across {langs.distinct} languages and {topics.length} topics. See <a href={routes.classification()}>/classification</a> for what this label covers.</p>

    <StatsRow stats={[
      { value: count.toLocaleString(), label: 'documents' },
      { value: String(langs.distinct), label: 'languages' },
      { value: String(topics.length), label: 'topics' },
    ]} />
  </div>

  {copy && (
    <section>
      <div class="section-label">What's in this slice</div>
      <p>{copy.description}</p>
      <p>{copy.useCases}</p>
    </section>
  )}

  <section>
    <div class="section-label">By topic</div>
    <table>
      <thead><tr><th>Topic</th><th class="right">Count</th></tr></thead>
      <tbody>
        {topics.map(r => (
          <tr>
            <td><a href={routes.topic(r.id)}>{r.label}</a></td>
            <td class="right mono">{r.count.toLocaleString()}</td>
          </tr>
        ))}
      </tbody>
    </table>
  </section>

  <section>
    <div class="section-label">Top languages</div>
    <table>
      <thead><tr><th>Lang</th><th class="right">Count</th><th class="right">Share</th></tr></thead>
      <tbody>
        {langs.languages.slice(0, 6).map(l => (
          <tr>
            <td class="mono">{l.code}</td>
            <td class="right mono">{l.count.toLocaleString()}</td>
            <td class="right mono">{l.percentage.toFixed(1)}%</td>
          </tr>
        ))}
        {langs.distinct > 6 && (
          <tr><td colspan="3" style="color: var(--muted); font-style: italic;">+ {langs.distinct - 6} more</td></tr>
        )}
      </tbody>
    </table>
    <p style="font-size:12px;color:var(--muted);margin-top:8px;">
      Share is computed against the top 20 languages for this type ({langs.denominator.toLocaleString()} docs),
      matching what the API returns. A handful of documents fall outside the top 20 or have no detected language.
    </p>
  </section>

  {samples.length > 0 && (
    <section>
      <div class="section-label">Sample documents <span class="count">· real rows from the corpus</span></div>
      <SamplesTable
        otherHeader="Topic"
        rows={samples.map(s => ({
          id: s.id,
          filename: s.filename ?? 'unknown',
          otherLabel: TOPIC_LABELS[s.topic] ?? s.topic,
          language: s.language ?? '',
          confidence: s.confidence,
        }))}
      />
    </section>
  )}

  <section>
    <div class="section-label">Access</div>
    <pre><code>{accessExample}</code></pre>
    <p>See <a href={routes.download()}>/download</a> for full access patterns.</p>
  </section>

  <SeeAlso links={[
    { label: 'All types', href: routes.typesIndex() },
    { label: 'All topics', href: routes.topicsIndex() },
    { label: '/classification', href: routes.classification() },
  ]} />
</DocPageLayout>
