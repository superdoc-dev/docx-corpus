---
import DocPageLayout from '../../layouts/DocPageLayout.astro';
import SeeAlso from '../../components/SeeAlso.astro';
import { routes } from '../../lib/routes';
import { getTypeFacets } from '../../lib/data';

const types = await getTypeFacets();
const totalTypes = types.length;
const totalDocs = types.reduce((s, t) => s + t.count, 0);

const title = `Document types in docx-corpus: ${totalTypes} categories, ${totalDocs.toLocaleString()} Word documents`;
const description = `Browse docx-corpus by document type. ${totalTypes} categories covering ${totalDocs.toLocaleString()} classified Word documents from Common Crawl.`;
---

<DocPageLayout
  title={title}
  description={description}
  canonicalPath={routes.typesIndex()}
  crumb={[{ name: 'Home', path: routes.home() }, { name: 'Types' }]}
>
  <div class="hero">
    <div class="kicker">Browse · {totalTypes} types</div>
    <h1>Document types</h1>
    <p class="sub">Each type describes a document's form (contract, form, report, etc.). Types are independent from topics, which describe subject domain. See <a href={routes.classification()}>/classification</a> for label definitions and the taxonomy.</p>
  </div>

  <section>
    <p>Each classified row has one type label and one topic label. Click through to browse a slice: counts per topic and language, sample documents, and a manifest URL for bulk download.</p>
    <table>
      <thead><tr><th>Type</th><th class="right">Documents</th></tr></thead>
      <tbody>
        {types.map(t => (
          <tr>
            <td><a href={routes.type(t.id)}>{t.label}</a></td>
            <td class="right mono">{t.count.toLocaleString()}</td>
          </tr>
        ))}
      </tbody>
    </table>
  </section>

  <SeeAlso links={[
    { label: 'Browse by topic', href: routes.topicsIndex() },
    { label: '/classification', href: routes.classification() },
    { label: '/download', href: routes.download() },
  ]} />
</DocPageLayout>
