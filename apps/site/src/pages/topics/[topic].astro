---
import DocPageLayout from '../../layouts/DocPageLayout.astro';
import StatsRow from '../../components/StatsRow.astro';
import SamplesTable from '../../components/SamplesTable.astro';
import SeeAlso from '../../components/SeeAlso.astro';
import { routes } from '../../lib/routes';
import { canonicalUrl } from '../../lib/seo';
import {
  getTopicFacets, getTypesForTopic, getLanguagesForTopic, getSamplesByTopic,
  TYPE_LABELS,
} from '../../lib/data';

export async function getStaticPaths() {
  const topics = await getTopicFacets();
  return topics.map(t => ({ params: { topic: t.id }, props: { topicFacet: t } }));
}

const { topic } = Astro.params;
const { topicFacet } = Astro.props;

const [types, langs, samples] = await Promise.all([
  getTypesForTopic(topic!),
  getLanguagesForTopic(topic!),
  getSamplesByTopic(topic!, 5),
]);

const label = topicFacet.label;
const count = topicFacet.count;
const topLangCodes = langs.languages.slice(0, 5).map(l => l.code).join(', ');

const title = `${label} Word documents: ${count.toLocaleString()} classified .docx files`;
const description = `${count.toLocaleString()}+ ${label.toLowerCase()} Word documents from the public web, in ${langs.distinct}+ languages including ${topLangCodes}. Free open dataset from docx-corpus.`;

const structuredData = {
  '@context': 'https://schema.org',
  '@type': 'Dataset',
  name: `docx-corpus - ${label} Documents`,
  description,
  url: canonicalUrl(routes.topic(topic!)),
  isPartOf: {
    '@type': 'Dataset',
    name: 'docx-corpus',
    url: canonicalUrl(routes.home()),
    license: 'https://opendatacommons.org/licenses/by/1-0/',
    creator: { '@type': 'Organization', name: 'SuperDoc', url: 'https://superdoc.dev' },
  },
  license: 'https://opendatacommons.org/licenses/by/1-0/',
  creator: { '@type': 'Organization', name: 'SuperDoc', url: 'https://superdoc.dev' },
};
---

<DocPageLayout
  title={title}
  description={description}
  canonicalPath={routes.topic(topic!)}
  structuredData={structuredData}
  crumb={[
    { name: 'Home', path: routes.home() },
    { name: 'Topics', path: routes.topicsIndex() },
    { name: label },
  ]}
>
  <div class="hero">
    <div class="kicker">Topic · {topic}</div>
    <h1>{label} Word documents</h1>
    <p class="sub">{count.toLocaleString()} documents across {langs.distinct} languages and {types.length} document types. See <a href={routes.classification()}>/classification</a> for what this label covers.</p>

    <StatsRow stats={[
      { value: count.toLocaleString(), label: 'documents' },
      { value: String(langs.distinct), label: 'languages' },
      { value: String(types.length), label: 'types' },
    ]} />
  </div>

  <section>
    <div class="section-label">By type</div>
    <table>
      <thead><tr><th>Type</th><th class="right">Count</th></tr></thead>
      <tbody>
        {types.map(r => (
          <tr>
            <td><a href={routes.type(r.id)}>{r.label}</a></td>
            <td class="right mono">{r.count.toLocaleString()}</td>
          </tr>
        ))}
      </tbody>
    </table>
  </section>

  <section>
    <div class="section-label">Top languages</div>
    <table>
      <thead><tr><th>Lang</th><th class="right">Count</th><th class="right">Share</th></tr></thead>
      <tbody>
        {langs.languages.slice(0, 6).map(l => (
          <tr>
            <td class="mono">{l.code}</td>
            <td class="right mono">{l.count.toLocaleString()}</td>
            <td class="right mono">{l.percentage.toFixed(1)}%</td>
          </tr>
        ))}
        {langs.distinct > 6 && (
          <tr><td colspan="3" style="color: var(--muted); font-style: italic;">+ {langs.distinct - 6} more</td></tr>
        )}
      </tbody>
    </table>
    <p style="font-size:12px;color:var(--muted);margin-top:8px;">
      Share is computed against the top 20 languages for this topic ({langs.denominator.toLocaleString()} docs),
      matching what the API returns. A handful of documents fall outside the top 20 or have no detected language.
    </p>
  </section>

  {samples.length > 0 && (
    <section>
      <div class="section-label">Sample documents <span class="count">· real rows from the corpus</span></div>
      <SamplesTable
        otherHeader="Type"
        rows={samples.map(s => ({
          id: s.id,
          filename: s.filename ?? 'unknown',
          otherLabel: TYPE_LABELS[s.type] ?? s.type,
          language: s.language ?? '',
          confidence: s.confidence,
        }))}
      />
    </section>
  )}

  <section>
    <div class="section-label">Access</div>
    <pre is:raw><span class="c"># All {label.toLowerCase()} documents</span>
curl <span class="c">"https://api.docxcorp.us/manifest?topic={topic}"</span> -o {topic}-manifest.txt

<span class="c"># High-confidence English subset</span>
curl <span class="c">"https://api.docxcorp.us/manifest?topic={topic}&lang=en&min_confidence=0.8"</span></pre>
    <p>See <a href={routes.download()}>/download</a> for full access patterns.</p>
  </section>

  <SeeAlso links={[
    { label: 'All topics', href: routes.topicsIndex() },
    { label: 'All types', href: routes.typesIndex() },
    { label: '/classification', href: routes.classification() },
  ]} />
</DocPageLayout>
